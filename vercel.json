{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "nodejs18.x"
      }
    },
    {
      "src": "build",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/(health|status)$",
      "dest": "/api.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api.js"
    },
    {
      "src": "^/(?!static).*\\..*$",
      "dest": "/build/$1"
    },
    {
      "src": "^/((?!api|health|status).)*$",
      "dest": "/build/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "PRISMA_DATABASE_URL": "@prisma_database_url",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production",
    "FRONTEND_URL": "@frontend_url",
    "REACT_APP_API_URL": "@react_app_api_url"
  }
}

