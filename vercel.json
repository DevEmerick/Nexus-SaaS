{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "DATABASE_URL": "@database_url",
    "PRISMA_DATABASE_URL": "@prisma_database_url",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production",
    "FRONTEND_URL": "@frontend_url",
    "REACT_APP_API_URL": "@react_app_api_url"
  },
  "redirects": [
    {
      "source": "/health",
      "destination": "/api.js",
      "statusCode": 307
    }
  ]
}
