# ============================================
# NEXUS SAAS - Environment Variables
# ============================================

# Database Configuration
# Get from Vercel Postgres dashboard (prisma.io console)
DATABASE_URL="postgresql://user:password@db.prisma.io:5432/database-name?sslmode=require"
PRISMA_DATABASE_URL="postgresql://user:password@db.prisma.io:5432/database-name?sslmode=require"

# JWT Secret (IMPORTANT: Use strong random string in production)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secure-random-string-here-change-in-production"

# Server Configuration
PORT=3001
NODE_ENV="development"

# Frontend URL (for CORS configuration)
# Development: http://localhost:3000
# Production: https://yourdomain.com
FRONTEND_URL="http://localhost:3000"

# ============================================
# Production Vercel Setup
# ============================================
# These variables should be set in Vercel Project Settings:
# 1. DATABASE_URL
# 2. PRISMA_DATABASE_URL  
# 3. JWT_SECRET
# 4. FRONTEND_URL
# 5. NODE_ENV = "production"

